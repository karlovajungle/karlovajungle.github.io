---
import { useTranslations, type Locale } from '../../i18n';
import { site } from '../../data/site';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'et' } = Astro.props;
const t = useTranslations(locale);
const { nav, header } = t.common;
const pathname = Astro.url.pathname;
const homeHref = locale === 'et' ? '/' : `/${locale}`;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(231, 240, 228, 0.08); backdrop-filter: blur(8px);"
>
  <div class="container-site">
    <nav class="flex items-center justify-between h-16 md:h-20" aria-label={nav.ariaLabel}>
      <!-- Logo -->
      <a href={homeHref} class="flex items-center shrink-0" aria-label={header.logoAriaLabel}>
        <img
          src="/images/logos/logo-leaf.svg"
          alt={header.logoAlt}
          class="h-8 md:h-10 w-auto"
          width="40"
          height="40"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6 lg:gap-8">
        {nav.links.map(link => (
          <a
            href={link.href}
            class={`text-sm font-sans font-medium tracking-wide transition-colors hover:text-[#6F8F72] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#6F8F72] ${
              pathname === (link.href as string) ? 'text-[#6F8F72]' : 'text-current'
            }`}
          >
            {link.label}
          </a>
        ))}
        <LanguageSwitcher locale={locale} pathname={pathname} />
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-2 px-5 py-2 text-sm font-sans font-medium tracking-wide border border-current rounded-sm transition-colors hover:bg-[#3F5A45] hover:border-[#3F5A45] hover:text-[#F4F7F2] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#6F8F72]"
        >
          {header.booking}
        </a>
      </div>

      <!-- Mobile: booking + menu toggle -->
      <div class="flex md:hidden items-center gap-3">
        <a
          href={site.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-1.5 text-sm font-sans font-medium border border-current rounded-sm"
        >
          {header.booking}
        </a>
        <button
          id="menu-toggle"
          type="button"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label={header.openMenu}
          class="p-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#6F8F72]"
        >
          <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="3" y1="7" x2="21" y2="7"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="17" x2="21" y2="17"/>
          </svg>
          <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="hidden">
            <line x1="4" y1="4" x2="20" y2="20"/>
            <line x1="20" y1="4" x2="4" y2="20"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label={header.mobileMenuLabel}
    class="hidden md:hidden"
    style="background: #F4F7F2;"
  >
    <div class="container-site py-6 flex flex-col gap-1 border-t border-[#C7D5C6]">
      {nav.links.map(link => (
        <a
          href={link.href}
          class={`py-3 text-base font-sans font-medium border-b border-[#C7D5C6] transition-colors hover:text-[#6F8F72] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#6F8F72] ${
            pathname === (link.href as string) ? 'text-[#6F8F72]' : 'text-[#1F2A22]'
          }`}
        >
          {link.label}
        </a>
      ))}
      <!-- Language switcher at bottom of mobile menu -->
      <div class="pt-4 mt-2 border-t border-[#C7D5C6]">
        <p class="text-xs font-medium uppercase tracking-widest text-[#6F8F72] mb-3">Language</p>
        <div class="flex gap-4">
          {[
            { code: 'et', label: 'Eesti',   href: (() => { const slug = pathname.replace(/^\/(en|ru)/, '') || '/'; return slug; })() },
            { code: 'en', label: 'English', href: (() => { const slug = pathname.replace(/^\/(en|ru)/, '') || '/'; return slug === '/' ? '/en' : `/en${slug}`; })() },
            { code: 'ru', label: 'Русский', href: (() => { const slug = pathname.replace(/^\/(en|ru)/, '') || '/'; return slug === '/' ? '/ru' : `/ru${slug}`; })() },
          ].map(lang => (
            <a
              href={lang.href}
              class={`text-sm font-sans ${lang.code === locale ? 'text-[#6F8F72] font-semibold' : 'text-[#1F2A22] hover:text-[#3F5A45]'} transition-colors`}
              aria-current={lang.code === locale ? 'true' : undefined}
            >
              {lang.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header') as HTMLElement;
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu') as HTMLElement;
  const iconOpen = document.getElementById('icon-open') as unknown as SVGElement;
  const iconClose = document.getElementById('icon-close') as unknown as SVGElement;

  function updateHeader() {
    if (window.scrollY > 40) {
      header.style.background = 'rgba(244, 247, 242, 0.96)';
      header.style.backdropFilter = 'blur(8px)';
      header.style.boxShadow = '0 1px 0 #C7D5C6';
    } else {
      header.style.background = 'rgba(231, 240, 228, 0.08)';
      header.style.backdropFilter = 'blur(8px)';
      header.style.boxShadow = '';
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    const isOpen = !menu.classList.contains('hidden');
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
  });

  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
