---
import type { Locale } from '../../i18n';

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;

// Strip locale prefix to get the slug
const slug = pathname.replace(/^\/(en|ru)/, '') || '/';

const languages = [
  { code: 'et' as Locale, label: 'Eesti',    href: slug },
  { code: 'en' as Locale, label: 'English',  href: slug === '/' ? '/en' : `/en${slug}` },
  { code: 'ru' as Locale, label: 'Русский',  href: slug === '/' ? '/ru' : `/ru${slug}` },
];

const current = languages.find(l => l.code === locale)!;
const others = languages.filter(l => l.code !== locale);
---

<div class="relative lang-switcher">
  <button
    type="button"
    aria-haspopup="listbox"
    aria-expanded="false"
    class="lang-trigger flex items-center gap-1.5 text-sm font-sans font-medium tracking-wide transition-colors hover:text-[#6F8F72] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#6F8F72]"
  >
    {current.label}
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="lang-chevron transition-transform duration-200">
      <polyline points="2 3 5 7 8 3"/>
    </svg>
  </button>

  <ul
    role="listbox"
    aria-label="Select language"
    class="lang-dropdown absolute top-full left-0 mt-2 hidden min-w-[8rem] border border-[#C7D5C6] rounded-sm bg-[#F4F7F2] shadow-sm py-1 z-50"
  >
    {others.map(lang => (
      <li role="option" aria-selected="false">
        <a
          href={lang.href}
          class="block px-4 py-2 text-sm font-sans text-[#1F2A22] hover:bg-[#E7F0E4] hover:text-[#3F5A45] transition-colors"
        >
          {lang.label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.lang-switcher').forEach(switcher => {
    const trigger = switcher.querySelector<HTMLButtonElement>('.lang-trigger')!;
    const dropdown = switcher.querySelector<HTMLElement>('.lang-dropdown')!;
    const chevron = switcher.querySelector<SVGElement>('.lang-chevron')!;

    function open() {
      dropdown.classList.remove('hidden');
      trigger.setAttribute('aria-expanded', 'true');
      chevron.style.transform = 'rotate(180deg)';
    }

    function close() {
      dropdown.classList.add('hidden');
      trigger.setAttribute('aria-expanded', 'false');
      chevron.style.transform = '';
    }

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.contains('hidden') ? open() : close();
    });

    document.addEventListener('click', () => close());

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  });
</script>
