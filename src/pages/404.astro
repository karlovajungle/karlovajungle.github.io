---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Lehte ei leitud — Karlova Jungle"
  noindex={true}
>
  <div class="pt-28 md:pt-36 section-spacing">
    <div class="container-site max-w-xl">
      <h1 class="font-serif text-4xl md:text-5xl text-[#1F2A22] mb-6">404</h1>
      <p class="text-[#516056] text-lg mb-8">Lehte ei leitud.</p>
      <a
        href="/"
        class="inline-block text-sm text-[#3F5A45] border-b border-[#6F8F72] hover:border-[#3F5A45] transition-colors"
      >
        ← Tagasi avalehele
      </a>
    </div>
  </div>
</PageLayout>
