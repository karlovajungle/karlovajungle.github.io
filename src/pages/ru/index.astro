---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import { useTranslations } from '../../i18n';

const locale = 'ru' as const;
const t = useTranslations(locale);
const { meta, about } = t.home;
---

<PageLayout
  title={meta.title}
  description={meta.description}
  locale={locale}
>
  <Hero locale={locale} />

  <section class="section-spacing bg-[#E7F0E4]" aria-labelledby="about-heading">
    <div class="container-site max-w-2xl mb-10 md:mb-12">
      <h2 id="about-heading" class="font-serif text-3xl md:text-4xl text-[#1F2A22] mb-6">
        {about.heading}
      </h2>
      <p class="text-[#516056] leading-relaxed text-lg">
        {about.text}
      </p>
    </div>
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
        {about.images.map(img => (
          <div class="aspect-square overflow-hidden rounded-sm bg-[#C7D5C6]">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
